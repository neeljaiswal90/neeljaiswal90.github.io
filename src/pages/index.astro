---
import CohesionLayout from '../layouts/CohesionLayout.astro';
import { getPublishableClaim } from '../data/claims';
import { roles } from '../data/experience';
import CompanyLogo from '../components/CompanyLogo.astro';
import { projects } from '../data/projects';
import { site } from '../data/site';
import { sources } from '../data/sources';
import { toolFilters, toolProfiles } from '../data/tools';
import { getPublishedClaim, workCases } from '../data/work';

const experience = getPublishableClaim('profile.experience.years_10_plus');
const location = getPublishableClaim('profile.location.greater_san_diego');
const locationLabel = location.displayValue ?? location.displayLabel ?? location.statement;
const rank = getPublishableClaim('jd_power.purchase_rank_1_value_mvno_2023');
const score = getPublishableClaim('jd_power.purchase_score_862_1000');
const aboveAverage = getPublishableClaim('jd_power.above_segment_average_51');
const stackCount = getPublishableClaim('stack.public_tool_inventory_27');
const jdPowerSource = sources.find((source) => source.id === 'src.jd_power.purchase_2023');
if (!jdPowerSource?.url) throw new Error('J.D. Power citation URL is missing.');

const heroSignals = [
  { category: 'Product leadership', claim: getPublishableClaim('career.mint.direct_reports_four_pm') },
  { category: 'Homepage growth', claim: getPublishableClaim('growth.homepage_conversion_lift_54_7') },
  { category: 'Plans growth', claim: getPublishableClaim('growth.plans_conversion_lift_77') },
  { category: 'Order economics', claim: getPublishableClaim('commerce.aov_lift_10_flat_conversion') },
  { category: 'Activation choice', claim: getPublishableClaim('esim.default_selection_lift_7_flat_conversion') },
  { category: 'New-business launch', claim: getPublishableClaim('kids.activations_14k_90_days') },
] as const;

const heroProof = heroSignals.slice(0, 4);

const focusAreas = [
  {
    number: '01',
    kicker: 'Ecommerce growth',
    title: 'Turn friction into compounding growth.',
    body: 'I connect funnel diagnosis, experimentation, merchandising, checkout, payments, and lifecycle into one measurable growth system.',
    claimIds: ['growth.homepage_conversion_lift_54_7', 'growth.plans_conversion_lift_77', 'commerce.aov_lift_10_flat_conversion'],
    tone: 'violet',
  },
  {
    number: '02',
    kicker: 'New-business launches',
    title: 'Build the journey and the operating model.',
    body: 'I connect eligibility, purchase, activation, service, and lifecycle into launches customers can understand and teams can operate.',
    claimIds: ['mhi.active_customers_29k_jan_2026', 'mhi.promo_purchase_rate_lift_60', 'kids.activations_14k_90_days'],
    tone: 'lime',
  },
  {
    number: '03',
    kicker: 'Commerce operating model',
    title: 'Make every dependency part of the product.',
    body: 'I design catalog, offers, checkout, payment risk, fulfillment, activation, support, and returns as one end-to-end product system.',
    claimIds: ['device.pixel_units_22_752', 'device.offer_configurations_100_plus', 'esim.eligible_purchase_mix_67_77'],
    tone: 'coral',
  },
  {
    number: '04',
    kicker: 'AI-enabled execution',
    title: 'Give AI evidence, tools, and boundaries.',
    body: 'I use AI to improve product and service execution, with retrieval, evaluation, escalation, and human approval designed into the workflow.',
    claimIds: ['ai.assistant.contacts_self_served_56', 'ai.assistant.csat_3_1_to_4_44', 'ai.assistant.escalations_reduced_34'],
    tone: 'ink',
  },
] as const;

const career = roles.map((role) => ({
  ...role,
  period: getPublishableClaim(role.periodClaimId).displayValue,
  summary: getPublishableClaim(role.summaryClaimId).statement,
}));

const workCards = workCases.filter((workCase) => workCase.featured).map((workCase) => ({
  ...workCase,
  metrics: workCase.metricClaimIds.slice(0, 3).map((claimId) => {
    const claim = getPublishedClaim(claimId);
    return {
      value: claim.displayValue ?? claim.displayLabel ?? 'Published',
      label: claim.displayLabel ?? 'Outcome',
    };
  }),
}));

const featuredToolIds = new Set(['amplitude', 'optimizely', 'figma', 'jira', 'snowflake', 'looker', 'codex', 'github', 'woocommerce', 'datadog']);
const featuredTools = toolProfiles.filter((tool) => featuredToolIds.has(tool.id));
const additionalTools = toolProfiles.filter((tool) => !featuredToolIds.has(tool.id));

const title = site.title;
const description = site.description;
---

<CohesionLayout
  title={title}
  description={description}
  ogImage="/assets/social-card-cohesion.png"
  ogImageAlt="Neel Jaiswal with the headline Make complex systems feel obvious, surrounded by playful dimensional forms"
>
  <header class="coh-topbar" aria-label="Portfolio navigation">
    <a class="coh-brand" href="#home" aria-label="Neel Jaiswal, back to top">
      <b>NJ</b><span>Neel Jaiswal<small>Senior Product Manager · Mint Mobile</small></span>
    </a>

    <nav class="coh-pill-nav" aria-label="Portfolio sections">
      <a class="is-active" href="#home" data-coh-nav="home">Home</a>
      <a href="#about" data-coh-nav="about">About</a>
      <a href="#focus" data-coh-nav="focus">Focus</a>
      <a href="#work" data-coh-nav="work">Work</a>
      <a href="#stack" data-coh-nav="stack">Stack</a>
      <a href="#contact" data-coh-nav="contact">Contact</a>
    </nav>

    <div class="coh-top-actions">
      <a class="coh-talk" href="#contact">Let’s talk <span aria-hidden="true">↓</span></a>
    </div>
  </header>

  <main id="cohesion-main">
    <section class="coh-hero" id="home" data-coh-section="home">
      <div class="coh-hero-intro" data-coh-reveal>
        <p class="coh-hero-eyebrow">Senior Product Manager · Mint Mobile · Since July 2020</p>
        <h1>I lead the ecommerce systems behind <em>Mint Mobile’s growth.</em></h1>
        <p class="coh-hero-summary">I own the portfolio from acquisition through post-purchase growth and directly manage four product managers.</p>
      </div>

      <p class="coh-hero-wordmark" aria-hidden="true"><span>NEEL</span><span>JAISWAL</span></p>

      <button
        class="coh-portrait-wrap"
        type="button"
        data-coh-reveal
        data-coh-portrait-flip
        data-intro-flip="pending"
        aria-expanded="false"
        aria-label="Reveal what Neel builds"
        aria-describedby="coh-portrait-flip-hint"
      >
        <span class="coh-portrait-flipper">
          <span class="coh-portrait-face coh-portrait-front">
            <img src={site.profileImage.path} alt={site.profileImage.alt} width={site.profileImage.width} height={site.profileImage.height} fetchpriority="high" decoding="async" />
            <span class="coh-portrait-caption"><b>Senior Product Manager</b><small>Mint Mobile · Since Jul 2020</small></span>
          </span>
          <span class="coh-portrait-face coh-portrait-back" aria-hidden="true">
            <small>What I lead</small>
            <strong>Mint Mobile’s ecommerce portfolio.</strong>
            <span>{heroSignals[0].claim.displayValue} · acquisition to post-purchase</span>
            <b aria-hidden="true">NJ</b>
          </span>
        </span>
      </button>
      <p class="coh-portrait-flip-hint" id="coh-portrait-flip-hint">
        <span class="coh-flip-hint-hover">Hover portrait to flip</span>
        <span class="coh-flip-hint-touch">Tap portrait to flip</span>
        <b aria-hidden="true">↻</b>
      </p>
      <span class="coh-sr-only" data-coh-portrait-status aria-live="polite"></span>

      <div class="coh-shape coh-shape-a" data-coh-depth="1" aria-hidden="true"></div>
      <div class="coh-shape coh-shape-b" data-coh-depth="2" aria-hidden="true"></div>
      <div class="coh-shape coh-shape-c" data-coh-depth="3" aria-hidden="true"></div>
      <div class="coh-shape coh-shape-d" data-coh-depth="2" aria-hidden="true"></div>
      <div class="coh-shape coh-shape-e" data-coh-depth="1" aria-hidden="true"></div>
      <div class="coh-shape coh-shape-f" data-coh-depth="3" aria-hidden="true"></div>

      <div class="coh-hero-trust coh-hero-proof" data-coh-reveal aria-label="Selected Mint Mobile portfolio evidence">
        {heroProof.map((signal) => (
          <span><strong>{signal.claim.displayValue}</strong><small>{signal.claim.displayLabel}</small></span>
        ))}
      </div>

      <div class="coh-hero-actions">
        <a class="coh-hero-cta" href="#work">View Mint impact <span aria-hidden="true">↓</span></a>
        <a class="coh-hero-secondary" href="/Neelesh_Jaiswal_Resume_Master.pdf">Résumé <span aria-hidden="true">↗</span></a>
      </div>
      <p class="coh-scroll-note" aria-hidden="true">Scroll to meet Neel</p>
    </section>

    <section class="coh-about" id="about" data-coh-section="about">
      <header class="coh-section-heading coh-about-heading" data-coh-reveal>
        <p>01 / About</p>
        <h2>Portfolio leadership,<br /><em>made measurable.</em></h2>
        <span>I turn customer behavior into roadmap choices, launch systems, and evidence-qualified business outcomes.</span>
      </header>

      <div class="coh-about-stage">
        <div class="coh-about-metrics" aria-label="Selected growth and business impact">
          {heroSignals.map((signal, index) => (
            <aside class={`coh-orbit-card coh-about-metric metric-${index + 1}`} data-coh-reveal>
              <small>{signal.category}</small>
              <strong>{signal.claim.displayValue}</strong>
              <span>{signal.claim.displayLabel}</span>
            </aside>
          ))}
        </div>

        <div class="coh-story-cards">
          <article class="coh-story-card" data-coh-reveal>
            <span>01 / Portfolio leader</span>
            <h3>I lead from acquisition through post-purchase growth.</h3>
            <p>At Mint Mobile, I own the ecommerce portfolio and directly manage four product managers. I align customer problems, commercial outcomes, operating dependencies, and team accountability before the roadmap becomes a queue of page requests.</p>
          </article>
          <article class="coh-story-card is-system" data-coh-reveal>
            <span>02 / Growth operating model</span>
            <h3>I give every roadmap decision evidence and a guardrail.</h3>
            <p>Instrumentation, experimentation, quality thresholds, and explicit ownership turn isolated launches into a system that compounds learning.</p>
            <header class="coh-loop-header">
              <span>Portfolio operating loop</span>
              <b><i aria-hidden="true"></i> Human governed</b>
            </header>
            <ol class="coh-release-loop">
              <li><span>01</span><div><small>Evidence</small><strong>Read the system</strong><p>Funnel · intent · service · operations</p></div></li>
              <li><span>02</span><div><small>Decision</small><strong>Choose the next action</strong><p>Hypothesis · confidence · guardrail</p></div></li>
              <li><span>03</span><div><small>Human gate</small><strong>Approve consequential change</strong><p>Owner · policy · rollback</p></div></li>
              <li><span>04</span><div><small>Release</small><strong>Ship, measure, and learn</strong><p>Outcome · exception · next cycle</p></div></li>
            </ol>
            <footer class="coh-loop-footer"><span><i aria-hidden="true"></i> Feedback active</span><b>Release → evidence</b></footer>
          </article>
          <article class="coh-story-card" data-coh-reveal>
            <span>03 / AI as a multiplier</span>
            <h3>I use AI to improve execution—not replace product judgment.</h3>
            <p>I apply retrieval, evaluation, tools, and human approval where they shorten the path from evidence to a safe release. The customer and business outcome stays primary.</p>
          </article>
        </div>
      </div>

      <section class="coh-proof-banner" aria-label="Experience and independent purchase experience recognition">
        <div class="coh-award-panel" data-coh-reveal>
          <a class="coh-award-record" href={jdPowerSource.url} target="_blank" rel="noopener" aria-label="Read the official J.D. Power 2023 purchase experience study">
            <span class="coh-award-brand">
              <CompanyLogo company="Mint Mobile" class="coh-award-logo" />
              <small>Mint Mobile</small>
            </span>
            <span class="coh-award-rank">
              <small>2023 purchase experience</small>
              <strong>{rank.displayValue}</strong>
              <span>Value MVNO segment</span>
            </span>
            <span class="coh-award-verify"><i aria-hidden="true"></i> Verified official result <b aria-hidden="true">↗</b></span>
          </a>
          <div class="coh-award-copy">
            <span>Independent commerce signal</span>
            <h2>Purchase experience ranked highest in its segment.</h2>
            <p>{rank.statement} Company-level recognition provides market context—not causal credit for one experiment.</p>
            <a href={jdPowerSource.url} target="_blank" rel="noopener">Official study <span aria-hidden="true">↗</span></a>
          </div>
        </div>
        <div class="coh-proof-stat" data-coh-reveal><small>Study score</small><strong>{score.displayValue}</strong><span>{score.displayLabel}</span></div>
        <div class="coh-proof-stat" data-coh-reveal><small>Segment delta</small><strong>{aboveAverage.displayValue}</strong><span>{aboveAverage.displayLabel}</span></div>
        <div class="coh-proof-stat is-experience" data-coh-reveal><small>Operating range</small><strong>{experience.displayValue}</strong><span>Ecommerce growth · agentic AI · enabling platforms</span></div>
      </section>

      <section class="coh-experience-deck" aria-labelledby="coh-experience-title" data-coh-reveal>
        <header class="coh-experience-heading">
          <p>Career depth</p>
          <h2 id="coh-experience-title">Senior Product Manager.<br /><em>Mint Mobile, Jul 2020—Present.</em></h2>
          <span>Open a role to inspect its scope, selected systems, capabilities, and linked case studies.</span>
        </header>

        <div class="coh-experience-list">
          {career.map((role, index) => (
            <details class="coh-experience-item" data-coh-experience open={index === 0}>
              <summary>
                <span class="coh-experience-index">{String(index + 1).padStart(2, '0')}</span>
                <span class="coh-experience-role">
                  <CompanyLogo company={role.company} class="coh-experience-logo" />
                  <span class="coh-experience-role-copy">
                    <small>{role.period}</small>
                    <strong>{role.company}</strong>
                    <i>{role.title}</i>
                  </span>
                </span>
                <span class="coh-experience-signal">{role.signal}</span>
                <span class="coh-experience-toggle" aria-hidden="true"></span>
              </summary>

              <div class="coh-experience-body">
                <div class="coh-experience-scope">
                  <small>Role scope</small>
                  <p>{role.summary}</p>
                </div>

                {role.achievements.length > 0 && (
                  <div class="coh-experience-systems">
                    <small>Selected systems</small>
                    <ul>
                      {role.achievements.map((achievement) => (
                        <li>
                          {achievement.href ? (
                            <a href={achievement.href}>
                              <span><b>{achievement.title}</b><small>{achievement.description}</small></span>
                              <i aria-hidden="true">↗</i>
                            </a>
                          ) : (
                            <div><span><b>{achievement.title}</b><small>{achievement.description}</small></span></div>
                          )}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                <div class="coh-experience-capabilities">
                  <small>Capabilities</small>
                  <ul>{role.tags.map((tag) => <li>{tag}</li>)}</ul>
                </div>
              </div>
            </details>
          ))}
        </div>
      </section>
    </section>

    <section class="coh-focus" id="focus" data-coh-section="focus">
      <header class="coh-focus-heading" data-coh-reveal>
        <div class="coh-focus-heading-copy">
          <p>02 / What I build</p>
          <h2>Mint ecommerce growth.<br /><em>From portfolio to launch.</em></h2>
          <span>Four connected systems for finding value, launching the operating model, and compounding what works.</span>
        </div>

        <a class="coh-focus-cue" href="#focus-system-01">
          <span class="coh-focus-cue-copy">
            <small>Below this frame</small>
            <strong>Scroll through four connected systems</strong>
          </span>
          <span class="coh-focus-cue-steps" aria-hidden="true">
            {focusAreas.map((area) => (
              <i><b>{area.number}</b><span>{area.kicker}</span></i>
            ))}
          </span>
          <span class="coh-focus-cue-arrow" aria-hidden="true">↓</span>
        </a>
      </header>

      <div class="coh-focus-stack">
        {focusAreas.map((area) => (
          <article class={`coh-focus-card tone-${area.tone}`} id={`focus-system-${area.number}`}>
            <span class="coh-focus-number" aria-hidden="true">{area.number}</span>
            <div class="coh-focus-copy" data-coh-reveal>
              <p>{area.number} / {area.kicker}</p>
              <h3>{area.title}</h3>
              <span>{area.body}</span>
            </div>
            <div class="coh-focus-metrics">
              {area.claimIds.map((claimId) => {
                const claim = getPublishableClaim(claimId);
                return (
                  <div data-coh-reveal>
                    <strong>{claim.displayValue ?? 'Published'}</strong>
                    <span>{claim.displayLabel ?? claim.statement}</span>
                  </div>
                );
              })}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="coh-work" id="work" data-coh-section="work">
      <header class="coh-section-heading coh-work-heading" data-coh-reveal>
        <p>03 / Selected work</p>
        <h2>Six systems.<br /><em>One growth thesis.</em></h2>
        <span>Growth, Home Internet, eSIM, Mint Kids, device commerce, and production AI—each with role, mandate, shipped work, impact, and evidence context.</span>
      </header>

      <div class="coh-work-grid">
        {workCards.map((item, index) => (
          <a class={`coh-work-card work-tone-${(index % 6) + 1}`} href={`/work/${item.slug}/`} data-coh-tilt data-coh-reveal>
            <div class="coh-work-meta">
              <span>{item.sequence} / {item.systemLabel}</span>
              <span class="coh-work-brand"><CompanyLogo company={item.company} class="coh-work-logo" /><i>{item.company}</i></span>
            </div>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
            <div class="coh-work-metrics">
              {item.metrics.length > 0
                ? item.metrics.map((metric) => <b>{metric.value}<small>{metric.label}</small></b>)
                : (item.supportingSignals ?? []).slice(0, 2).map((signal) => <b>{signal.value}<small>{signal.label}</small></b>)}
            </div>
            <span class="coh-card-link">Read case study <i aria-hidden="true">↗</i></span>
          </a>
        ))}
      </div>
    </section>

    <section class="coh-stack" id="stack" data-coh-section="stack">
      <header class="coh-stack-heading" data-coh-reveal>
        <p>04 / Stack</p>
        <h2>A focused operating stack.<br /><em>Depth before logo count.</em></h2>
        <span>Ten core tools support product decisions and delivery. The full {stackCount.displayValue} inventory is available on demand.</span>
      </header>

      <div class="coh-tool-stage">
        <div class="coh-tool-toolbar" data-coh-reveal>
          <div class="coh-tool-filters" role="group" aria-label="Filter the public tool inventory">
            {toolFilters.map((filter, index) => (
              <button type="button" data-coh-tool-filter={filter.id} aria-pressed={index === 0 ? 'true' : 'false'}>{filter.label}</button>
            ))}
          </div>
          <span id="coh-tool-count">{featuredTools.length} featured · {toolProfiles.length} total</span>
        </div>
        <p class="coh-sr-only" id="coh-tool-announcement" aria-live="polite"></p>
        <ul class="coh-tool-grid coh-tool-grid-featured" aria-label="Featured product and technical tools">
          {featuredTools.map((tool) => (
            <li data-coh-reveal data-coh-tool data-coh-tool-featured data-coh-tool-groups={tool.groups.join(' ')}>
              <img src={tool.assetPath} alt="" width="56" height="56" loading="lazy" decoding="async" />
              <b>{tool.name}</b>
              <span>{tool.detail}</span>
            </li>
          ))}
        </ul>
        <details class="coh-tool-library" data-coh-tool-library>
          <summary>View full stack <span>{additionalTools.length} additional tools</span></summary>
          <ul class="coh-tool-grid coh-tool-grid-more" aria-label="Additional product and technical tools">
            {additionalTools.map((tool) => (
              <li data-coh-reveal data-coh-tool data-coh-tool-groups={tool.groups.join(' ')}>
                <img src={tool.assetPath} alt="" width="56" height="56" decoding="async" />
                <b>{tool.name}</b>
                <span>{tool.detail}</span>
              </li>
            ))}
          </ul>
        </details>
      </div>

      <div class="coh-builds" data-coh-reveal>
        <div class="coh-build-intro">
          <p>Public builds</p>
          <h3>I build what<br />I manage.</h3>
          <a href={site.contact.github} target="_blank" rel="noopener">View GitHub <span aria-hidden="true">↗</span></a>
        </div>
        {projects.map((project, index) => (
          <a class={`coh-build-card build-${index + 1}`} href={project.url} target="_blank" rel="noopener">
            <span>{String(index + 1).padStart(2, '0')} / {project.defaultBranch}</span>
            <h3>{project.title}</h3>
            <p>{project.summary}</p>
            <ul>{project.technologies.map((technology) => <li>{technology}</li>)}</ul>
            <i aria-hidden="true">↗</i>
          </a>
        ))}
      </div>
    </section>

    <section class="coh-contact" id="contact" data-coh-section="contact">
      <div class="coh-contact-shape" aria-hidden="true"></div>
      <p data-coh-reveal>05 / Contact · {locationLabel}</p>
      <h2 data-coh-reveal>Let’s build commerce<br /><em>that learns and acts.</em></h2>
      <div class="coh-contact-actions" data-coh-reveal>
        <a href={`mailto:${site.contact.email}`}>{site.contact.email} <span aria-hidden="true">↗</span></a>
        <a href="/Neelesh_Jaiswal_Resume_Master.pdf">Résumé <span aria-hidden="true">↓</span></a>
        <a href={site.contact.linkedin} target="_blank" rel="noopener">LinkedIn <span aria-hidden="true">↗</span></a>
        <a href={site.contact.github} target="_blank" rel="noopener">GitHub <span aria-hidden="true">↗</span></a>
      </div>
      <footer>
        <span>Neel Jaiswal · Senior Product Manager, Mint Mobile</span>
        <a href="#home">Back to top</a>
        <span>© {new Date().getFullYear()}</span>
      </footer>
    </section>
  </main>
</CohesionLayout>
