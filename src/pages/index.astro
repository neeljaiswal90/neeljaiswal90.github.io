---
import CohesionLayout from '../layouts/CohesionLayout.astro';
import { getPublishableClaim } from '../data/claims';
import { getPublishableMedia } from '../data/media';
import { roles } from '../data/experience';
import CompanyLogo from '../components/CompanyLogo.astro';
import ResponsiveMedia from '../components/ResponsiveMedia.astro';
import { projects } from '../data/projects';
import { site } from '../data/site';
import { sources } from '../data/sources';
import { toolFilters, toolProfiles } from '../data/tools';
import { workCases } from '../data/work';

const location = getPublishableClaim('profile.location.greater_san_diego');
const locationLabel = location.displayValue ?? location.displayLabel ?? location.statement;
const headshot = getPublishableMedia('media.profile.headshot');
const rank = getPublishableClaim('jd_power.purchase_rank_1_value_mvno_2023');
const score = getPublishableClaim('jd_power.purchase_score_862_1000');
const aboveAverage = getPublishableClaim('jd_power.above_segment_average_51');
const studyResponses = getPublishableClaim('jd_power.study_responses_14519');
const stackCount = getPublishableClaim('stack.public_tool_inventory_27');
const jdPowerSource = sources.find((source) => source.id === 'src.jd_power.purchase_2023');
if (!jdPowerSource?.url) throw new Error('J.D. Power citation URL is missing.');

const leadershipClaim = getPublishableClaim('career.mint.product_leadership_team_of_pms');

const heroCapabilities = [
  {
    eyebrow: 'Skill',
    title: 'Ecommerce growth',
    detail: 'Funnel · lifecycle · revenue',
    symbol: '↗',
    context: 'I connect acquisition, merchandising, checkout, and lifecycle into one measurable growth system.',
  },
  {
    eyebrow: 'Products shipped',
    title: 'Products 0–1',
    detail: 'Checkout · Home Internet · kids mobile',
    symbol: '＋',
    context: 'I build the customer journey and operating model—from eligibility through activation and adoption.',
  },
  {
    eyebrow: 'Technology',
    title: 'Applied AI + platforms',
    detail: 'Agentic workflows · APIs · data',
    symbol: '⌘',
    context: 'I translate AI, APIs, data, and platform constraints into products teams can operate and scale.',
  },
  {
    eyebrow: 'Leadership',
    title: leadershipClaim.displayValue,
    detail: `${leadershipClaim.displayLabel} · portfolio ownership`,
    symbol: '◎',
    context: 'I align teams of PMs around outcomes, evidence, dependencies, and clear ownership.',
  },
] as const;

const aboutPrinciples = [
  {
    number: '01',
    kicker: 'Portfolio leadership',
    title: 'Lead the portfolio.',
    body: 'Align customer needs, commercial outcomes, dependencies, and ownership before work enters the roadmap.',
    claimIds: ['career.mint.product_leadership_team_of_pms', 'growth.core_funnel_conversion_lift_54_7'],
    tone: 'violet',
  },
  {
    number: '02',
    kicker: 'Evidence to release',
    title: 'Turn evidence into releases.',
    body: 'Use instrumentation, experiments, guardrails, and clear ownership to ship safely and compound learning.',
    claimIds: ['growth.cart_checkout_conversion_lift_77', 'commerce.aov_lift_10'],
    tone: 'lime',
  },
  {
    number: '03',
    kicker: 'Applied AI',
    title: 'Use AI with judgment.',
    body: 'Apply retrieval, evaluation, tools, and human approval where they improve execution without replacing accountability.',
    claimIds: ['ai.assistant.contacts_self_served_56', 'ai.assistant.csat_3_1_to_4_44'],
    tone: 'ink',
  },
] as const;

const focusAreas = [
  {
    number: '01',
    kicker: 'Core funnel + cart / checkout',
    title: 'Turn friction into compounding growth.',
    body: 'I connect funnel diagnosis, experimentation, merchandising, checkout, payments, and lifecycle into one measurable growth system.',
    claimIds: ['growth.core_funnel_conversion_lift_54_7', 'growth.cart_checkout_conversion_lift_77', 'commerce.aov_lift_10'],
    tone: 'violet',
  },
  {
    number: '02',
    kicker: 'New-business launches',
    title: 'Build the journey and the operating model.',
    body: 'I connect eligibility, purchase, activation, service, and lifecycle into launches customers can understand and teams can operate.',
    claimIds: ['mhi.active_customers_29k_jan_2026', 'mhi.promo_purchase_rate_lift_60', 'kids.activations_14k_90_days'],
    tone: 'lime',
  },
  {
    number: '03',
    kicker: 'Commerce platforms',
    title: 'Make every dependency part of the product.',
    body: 'I design catalog, offers, checkout, payment risk, fulfillment, activation, support, and returns as one end-to-end product system.',
    claimIds: ['device.units_sold_22_752', 'device.offer_configurations_100_plus', 'esim.eligible_purchase_mix_67_77'],
    tone: 'coral',
  },
  {
    number: '04',
    kicker: 'AI-enabled service',
    title: 'Give AI evidence, tools, and boundaries.',
    body: 'I use AI to improve product and service execution, with retrieval, evaluation, escalation, and human approval designed into the workflow.',
    claimIds: ['ai.assistant.contacts_self_served_56', 'ai.assistant.csat_3_1_to_4_44', 'ai.assistant.escalations_reduced_34'],
    tone: 'ink',
  },
] as const;

const career = roles.map((role) => ({
  ...role,
  period: getPublishableClaim(role.periodClaimId).displayValue,
  summary: getPublishableClaim(role.summaryClaimId).statement,
}));

const workCards = workCases
  .filter((workCase) => workCase.featured)
  .map((workCase) => ({
    ...workCase,
    metrics: workCase.metricClaimIds.slice(0, 2).map((claimId) => {
      const claim = getPublishableClaim(claimId);
      return {
        value: claim.displayValue ?? claim.displayLabel ?? 'Published',
        label: claim.displayLabel ?? claim.statement,
      };
    }),
  }));

const featuredToolIds = new Set(['amplitude', 'optimizely', 'figma', 'jira', 'snowflake', 'looker', 'codex', 'github', 'woocommerce', 'datadog']);
const featuredTools = toolProfiles.filter((tool) => featuredToolIds.has(tool.id));
const additionalTools = toolProfiles.filter((tool) => !featuredToolIds.has(tool.id));

const title = site.title;
const description = site.description;
const contactFormEndpoint = '/api/contact';
---

<CohesionLayout
  title={title}
  description={description}
  ogImage="/assets/social-card-live-v4.png"
  ogImageAlt="Neel Jaiswal with ecommerce growth, 0-to-1 launches, and AI that actually ships"
>
  <main id="cohesion-main">
    <section class="coh-hero" id="home" data-coh-section="home" data-coh-journey data-coh-journey-label="Home">
  <header class="coh-identity-header" data-coh-identity-header>
    <h1 aria-label="Hi, I’m Neel. I build conversion engines, ecommerce growth systems, agentic AI workflows, and AI resolution products.">
      <span class="coh-intro-greeting">Hi, I’m <em>Neel.</em></span>
      <span class="coh-intro-divider" aria-hidden="true">/</span>
      <span class="coh-role-line">I build <span class="coh-role-viewport" aria-hidden="true"><strong data-role-cycle>conversion engines</strong></span></span>
    </h1>
  </header>

  <header class="coh-topbar" aria-label="Portfolio navigation" data-coh-nav-header>
    <a class="coh-brand" href="#home" aria-label="Neel Jaiswal, back to top">
      <b>NJ</b><span>Neel Jaiswal<small>Senior Product Manager · Mint Mobile</small></span>
    </a>

    <nav class="coh-pill-nav" aria-label="Portfolio sections">
      <a class="is-active" href="#home" data-coh-nav="home">Home</a>
      <a href="#about" data-coh-nav="about">About</a>
      <a href="#focus" data-coh-nav="focus">Systems</a>
      <a href="#work" data-coh-nav="work">Work</a>
      <a href="#stack" data-coh-nav="stack">Stack</a>
      <a href="#contact" data-coh-nav="contact">Contact</a>
    </nav>

    <div class="coh-top-actions">
      <a class="coh-talk" href="#contact">Let’s talk <span aria-hidden="true">↓</span></a>
    </div>
  </header>

      <div class="coh-hero-wordmark" aria-hidden="true">
        <div class="coh-hero-wordmark-track">
          <span class="coh-hero-wordmark-group"><b>NEEL JAISWAL</b><i>·</i><b>NEEL JAISWAL</b><i>·</i></span>
          <span class="coh-hero-wordmark-group"><b>NEEL JAISWAL</b><i>·</i><b>NEEL JAISWAL</b><i>·</i></span>
        </div>
      </div>

      <button
        class="coh-portrait-wrap"
        type="button"
        data-coh-reveal
        data-coh-portrait-flip
        data-intro-flip="pending"
        aria-pressed="false"
        aria-label="Reveal Neel’s product leadership approach"
      >
        <span class="coh-portrait-flipper">
          <span class="coh-portrait-face coh-portrait-front" aria-hidden="false">
            <ResponsiveMedia media={headshot} width={site.profileImage.width} height={site.profileImage.height} loading="eager" fetchpriority="high" />
            <span class="coh-portrait-caption"><b>Senior Product Manager</b><small>Ecommerce · growth · AI</small></span>
          </span>
          <span class="coh-portrait-face coh-portrait-back" aria-hidden="true">
            <small>Senior product leadership</small>
            <strong>Complex portfolios. Clear decisions. Measurable growth.</strong>
            <span>Ecommerce · 0-to-1 products · applied AI</span>
            <b aria-hidden="true">NJ</b>
          </span>
        </span>
      </button>
      <span class="coh-sr-only" data-coh-portrait-status aria-live="polite"></span>

      <div class="coh-hero-trust coh-hero-proof" data-coh-reveal role="list" aria-label="Core product capabilities and leadership">
        {heroCapabilities.map((capability) => (
          <span class="coh-hero-capability-item" role="listitem">
            <button
              class="coh-hero-capability"
              type="button"
              data-coh-capability
              aria-pressed="false"
              aria-label={`${capability.title}. ${capability.detail}. Activate for more context.`}
            >
              <span class="coh-hero-capability-inner">
                <span class="coh-hero-capability-face coh-hero-capability-front" aria-hidden="true">
                  <i aria-hidden="true">{capability.symbol}</i>
                  <span>
                    <small>{capability.eyebrow}</small>
                    <strong>{capability.title}</strong>
                    <em>{capability.detail}</em>
                  </span>
                </span>
                <span class="coh-hero-capability-face coh-hero-capability-back" aria-hidden="true">
                  <small>How I work</small>
                  <strong>{capability.title}</strong>
                  <em>{capability.context}</em>
                </span>
              </span>
            </button>
          </span>
        ))}
      </div>

      <a class="coh-hero-next-cta" href="#about" data-coh-hero-next aria-label="Continue to the About section">
        <span aria-hidden="true">
          <b>Explore how I lead</b>
          <b>Continue to About</b>
        </span>
        <i aria-hidden="true">↓</i>
      </a>
    </section>

    <nav class="coh-mobile-nav" aria-label="Mobile portfolio navigation" data-coh-mobile-nav>
      <a class="is-active" href="#home" data-coh-nav="home">Top</a>
      <a href="#about" data-coh-nav="about">About</a>
      <a href="#focus" data-coh-nav="focus" data-coh-nav-alias="stack">Systems</a>
      <a href="#work" data-coh-nav="work">Work</a>
      <a href="#contact" data-coh-nav="contact">Contact</a>
    </nav>

    <nav class="coh-journey-nav" data-coh-journey-nav aria-label="Navigate the portfolio journey" aria-hidden="true" inert>
      <button type="button" data-coh-journey-previous aria-label="Previous component">
        <span aria-hidden="true">↑</span>
      </button>
      <span class="coh-journey-status" aria-live="polite">
        <small>Journey</small>
        <b data-coh-journey-label>About</b>
        <i data-coh-journey-progress>01 / 17</i>
      </span>
      <button type="button" data-coh-journey-next aria-label="Next component">
        <span aria-hidden="true">↓</span>
      </button>
    </nav>

    <section class="coh-about" id="about" data-coh-section="about">
      <header class="coh-section-heading coh-about-heading" data-coh-reveal data-coh-snap data-coh-journey data-coh-journey-label="About">
        <p>01 / About</p>
        <h2>How I lead.</h2>
        <span>Portfolio ownership, evidence-led decisions, and applied AI.</span>
      </header>

      <div class="coh-about-stack">
        {aboutPrinciples.map((principle) => (
          <article class={`coh-focus-card coh-about-card tone-${principle.tone}`} id={`about-principle-${principle.number}`} data-coh-snap data-coh-journey data-coh-journey-label={principle.kicker}>
            <span class="coh-focus-number" aria-hidden="true">{principle.number}</span>
            <div class="coh-focus-copy" data-coh-reveal>
              <p>{principle.number} / {principle.kicker}</p>
              <h3>{principle.title}</h3>
              <span>{principle.body}</span>
            </div>
            <div class="coh-focus-metrics" aria-label={`Selected evidence for ${principle.kicker}`}>
              {principle.claimIds.map((claimId) => {
                const claim = getPublishableClaim(claimId);
                return (
                  <div data-coh-reveal>
                    <strong>{claim.displayValue ?? 'Published'}</strong>
                    <span>{claim.displayLabel ?? claim.statement}</span>
                  </div>
                );
              })}
            </div>
          </article>
        ))}
      </div>

      <section class="coh-proof-banner" aria-label="J.D. Power 2023 purchase experience recognition" data-coh-snap data-coh-journey data-coh-journey-label="Recognition">
        <div class="coh-award-panel" data-coh-reveal>
          <a class="coh-award-record" href={jdPowerSource.url} target="_blank" rel="noopener" aria-label="Read the official J.D. Power 2023 purchase experience study">
            <img
              src="/assets/jd-power-2023-purchase-experience-award.webp"
              alt="Illustrated 2023 J.D. Power U.S. Wireless Purchase Experience award presented to Mint Mobile"
              width="1440"
              height="756"
              loading="lazy"
              decoding="async"
            />
          </a>
          <div class="coh-award-copy">
            <span>J.D. Power recognition · 2023</span>
            <h2>{rank.displayValue} in value MVNO purchase experience.</h2>
            <p>Mint Mobile ranked highest in its inaugural year of eligibility. The study program drew responses from {studyResponses.displayValue} wireless customers across phone, store, website, and app purchase journeys.</p>
            <a href={jdPowerSource.url} target="_blank" rel="noopener">Official study <span aria-hidden="true">↗</span></a>
          </div>
        </div>
        <div class="coh-proof-stat" data-coh-reveal><small>Study score</small><strong>{score.displayValue}</strong><span>{score.displayLabel}</span></div>
        <div class="coh-proof-stat" data-coh-reveal><small>Segment delta</small><strong>{aboveAverage.displayValue}</strong><span>{aboveAverage.displayLabel}</span></div>
        <div class="coh-proof-stat is-sample" data-coh-reveal><small>Customer voices</small><strong>{studyResponses.displayValue}</strong><span>{studyResponses.displayLabel}</span></div>
      </section>

      <section class="coh-experience-deck" aria-labelledby="coh-experience-title" data-coh-reveal data-coh-snap data-coh-journey data-coh-journey-label="Career depth">
        <header class="coh-experience-heading">
          <p>Career depth</p>
          <h2 id="coh-experience-title">Product leadership across industries.</h2>
          <span>Open a role for scope, systems, and selected work.</span>
        </header>

        <div class="coh-experience-list">
          {career.map((role, index) => (
            <details class="coh-experience-item" data-coh-experience open={index === 0}>
              <summary>
                <span class="coh-experience-index">{String(index + 1).padStart(2, '0')}</span>
                <span class="coh-experience-role">
                  <CompanyLogo company={role.company} class="coh-experience-logo" />
                  <span class="coh-experience-role-copy">
                    <small>{role.period}</small>
                    <strong>{role.company}</strong>
                    <i>{role.title}</i>
                  </span>
                </span>
                <span class="coh-experience-signal">{role.signal}</span>
                <span class="coh-experience-toggle" aria-hidden="true"></span>
              </summary>

              <div class="coh-experience-body">
                <div class="coh-experience-scope">
                  <small>Role scope</small>
                  <p>{role.summary}</p>
                </div>

                {role.achievements.length > 0 && (
                  <div class="coh-experience-systems">
                    <small>Selected systems</small>
                    <ul>
                      {role.achievements.map((achievement) => (
                        <li>
                          {achievement.href ? (
                            <a href={achievement.href}>
                              <span><b>{achievement.title}</b><small>{achievement.description}</small></span>
                              <i aria-hidden="true">↗</i>
                            </a>
                          ) : (
                            <div><span><b>{achievement.title}</b><small>{achievement.description}</small></span></div>
                          )}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                <div class="coh-experience-capabilities">
                  <small>Capabilities</small>
                  <ul>{role.tags.map((tag) => <li>{tag}</li>)}</ul>
                </div>
              </div>
            </details>
          ))}
        </div>
      </section>
    </section>

    <section class="coh-focus" id="focus" data-coh-section="focus">
      <header class="coh-focus-heading" data-coh-reveal data-coh-snap data-coh-journey data-coh-journey-label="What I build">
        <div class="coh-focus-heading-copy">
          <p>02 / What I build</p>
          <h2>Systems built to perform.</h2>
          <span>Four connected systems across growth, launches, platforms, and AI.</span>
        </div>

        <a class="coh-focus-cue" href="#focus-system-01">
          <span class="coh-focus-cue-copy">
            <small>Below this frame</small>
            <strong>Scroll through four connected systems</strong>
          </span>
          <span class="coh-focus-cue-steps" aria-hidden="true">
            {focusAreas.map((area) => (
              <i><b>{area.number}</b><span>{area.kicker}</span></i>
            ))}
          </span>
          <span class="coh-focus-cue-arrow" aria-hidden="true">↓</span>
        </a>
      </header>

      <div class="coh-focus-stack">
        {focusAreas.map((area) => (
          <article class={`coh-focus-card tone-${area.tone}`} id={`focus-system-${area.number}`} data-coh-journey data-coh-journey-label={`${area.number} · ${area.kicker}`}>
            <span class="coh-focus-number" aria-hidden="true">{area.number}</span>
            <div class="coh-focus-copy" data-coh-reveal>
              <p>{area.number} / {area.kicker}</p>
              <h3>{area.title}</h3>
              <span>{area.body}</span>
            </div>
            <div class="coh-focus-metrics">
              {area.claimIds.map((claimId) => {
                const claim = getPublishableClaim(claimId);
                return (
                  <div data-coh-reveal>
                    <strong>{claim.displayValue ?? 'Published'}</strong>
                    <span>{claim.displayLabel ?? claim.statement}</span>
                  </div>
                );
              })}
            </div>
          </article>
        ))}
      </div>

    </section>

    <section class="coh-work" id="work" data-coh-section="work">
      <header class="coh-section-heading coh-work-heading" data-coh-reveal data-coh-snap data-coh-journey data-coh-journey-label="Selected work">
        <p>03 / Selected work</p>
        <h2>Explore the work.</h2>
        <span>Six case studies across growth, launches, platforms, and AI.</span>
      </header>

      <p class="coh-work-rail-cue"><span>Swipe through 6</span><i aria-hidden="true">→</i></p>

      <div class="coh-work-tiles" role="list" aria-label="Six selected case studies" data-coh-reveal data-coh-snap data-coh-journey data-coh-journey-label="Case studies">
        {workCards.map((workCase, index) => (
          <article class={`coh-work-tile coh-work-tile-tone-${index + 1}`} role="listitem">
            <a
              href={`/work/${workCase.slug}/`}
              aria-label={`${workCase.company}: ${workCase.indexTitle} Read case study`}
              aria-describedby={`work-tile-${workCase.slug}-description`}
            >
              <div class="coh-work-tile-inner">
                <div class="coh-work-tile-face coh-work-tile-front" aria-hidden="true">
                  <div class="coh-work-tile-topline">
                    <span>{workCase.sequence} / {workCase.systemLabel}</span>
                    <CompanyLogo company={workCase.company} class="coh-work-tile-logo" />
                  </div>
                  <h3>{workCase.indexTitle}</h3>
                  <div class="coh-work-tile-prompt">
                    <span class="coh-work-tile-desktop-prompt">Hover to explore</span>
                    <span class="coh-work-tile-touch-prompt">Tap to read</span>
                    <i aria-hidden="true">↗</i>
                  </div>
                </div>

                <div class="coh-work-tile-face coh-work-tile-back" aria-hidden="true">
                  <div class="coh-work-tile-topline">
                    <span>{workCase.company}</span>
                    <b>{workCase.sequence}</b>
                  </div>
                  <h3>{workCase.indexTitle}</h3>
                  <p>{workCase.summary}</p>
                  <div class="coh-work-tile-metrics">
                    {workCase.metrics.map((metric) => (
                      <span><strong>{metric.value}</strong><small>{metric.label}</small></span>
                    ))}
                  </div>
                  <div class="coh-work-tile-link">
                    <span>Read case study</span>
                    <i aria-hidden="true">↗</i>
                  </div>
                </div>
              </div>
              <span class="coh-sr-only sr-only" id={`work-tile-${workCase.slug}-description`}>
                {workCase.summary} Selected outcomes: {workCase.metrics.map((metric) => `${metric.value}, ${metric.label}`).join('; ')}.
              </span>
            </a>
          </article>
        ))}
      </div>

      <a class="coh-work-all" href="/work/">
        <span>Selected work index</span>
        <strong>View all six case studies</strong>
        <i aria-hidden="true">↗</i>
      </a>
    </section>

    <section class="coh-stack" id="stack" data-coh-section="stack">
      <header class="coh-stack-heading" data-coh-reveal data-coh-snap data-coh-journey data-coh-journey-label="Operating stack">
        <p>04 / Stack</p>
        <h2>Tools I use.</h2>
        <span>{stackCount.displayValue} across product, design, data, and delivery.</span>
      </header>

      <div class="coh-tool-stage" data-coh-snap data-coh-journey data-coh-journey-label="Tools">
        <div class="coh-tool-toolbar" data-coh-reveal>
          <div class="coh-tool-filters" role="group" aria-label="Filter the public tool inventory">
            {toolFilters.map((filter, index) => (
              <button type="button" data-coh-tool-filter={filter.id} aria-pressed={index === 0 ? 'true' : 'false'}>{filter.label}</button>
            ))}
          </div>
          <span id="coh-tool-count">{featuredTools.length} featured · {toolProfiles.length} total</span>
        </div>
        <p class="coh-sr-only" id="coh-tool-announcement" aria-live="polite"></p>
        <ul class="coh-tool-grid coh-tool-grid-featured" aria-label="Featured product and technical tools">
          {featuredTools.map((tool) => (
            <li data-coh-reveal data-coh-tool data-coh-tool-featured data-coh-tool-groups={tool.groups.join(' ')}>
              <img src={tool.assetPath} alt="" width="56" height="56" loading="lazy" decoding="async" />
              <b>{tool.name}</b>
              <span>{tool.detail}</span>
            </li>
          ))}
        </ul>
        <details class="coh-tool-library" data-coh-tool-library>
          <summary>View full stack <span>{additionalTools.length} additional tools</span></summary>
          <ul class="coh-tool-grid coh-tool-grid-more" aria-label="Additional product and technical tools">
            {additionalTools.map((tool) => (
              <li data-coh-reveal data-coh-tool data-coh-tool-groups={tool.groups.join(' ')}>
                <img src={tool.assetPath} alt="" width="56" height="56" decoding="async" />
                <b>{tool.name}</b>
                <span>{tool.detail}</span>
              </li>
            ))}
          </ul>
        </details>
      </div>

      <div class="coh-builds" data-coh-reveal data-coh-snap data-coh-journey data-coh-journey-label="Selected builds">
        <div class="coh-build-intro">
          <p>Selected builds</p>
          <h3>Products I’ve built.</h3>
          <a href={site.contact.github} target="_blank" rel="noopener">View GitHub <span aria-hidden="true">↗</span></a>
        </div>
        {projects.map((project, index) => project.url ? (
          <a
            class={`coh-build-card build-${index + 1}`}
            href={project.url}
            target="_blank"
            rel="noopener"
            aria-label={`${project.title} — ${project.accessLabel} (opens in a new tab)`}
          >
            <span>{String(index + 1).padStart(2, '0')} / {project.accessLabel}</span>
            <h3>{project.title}</h3>
            <p>{project.summary}</p>
            <ul>{project.technologies.map((technology) => <li>{technology}</li>)}</ul>
            <i aria-hidden="true">↗</i>
          </a>
        ) : (
          <article class={`coh-build-card is-private build-${index + 1}`} aria-label={`${project.title} — ${project.accessLabel}`}>
            <span>{String(index + 1).padStart(2, '0')} / {project.accessLabel}</span>
            <h3>{project.title}</h3>
            <p>{project.summary}</p>
            <ul>{project.technologies.map((technology) => <li>{technology}</li>)}</ul>
            <i aria-hidden="true">Private</i>
          </article>
        ))}
      </div>
    </section>

    <section class="coh-contact" id="contact" data-coh-section="contact" data-coh-snap data-coh-journey data-coh-journey-label="Contact">
      <div class="coh-contact-shape" aria-hidden="true"></div>
      <div class="coh-contact-grid">
        <div class="coh-contact-intro">
          <p data-coh-reveal>05 / Contact · {locationLabel}</p>
          <h2 data-coh-reveal>You’re looking to grow your product.<br /><em>Let’s build what’s next.</em></h2>
          <p class="coh-contact-lead" data-coh-reveal>
            Growth, commerce, and AI products customers choose and businesses can scale.
          </p>
          <nav class="coh-contact-actions" aria-label="Contact, social, and résumé links" data-coh-reveal>
            <a class="is-email" href={`mailto:${site.contact.email}`}>
              <span class="coh-contact-link-mark" aria-hidden="true">@</span>
              <span><small>Email</small>{site.contact.email}</span>
              <i aria-hidden="true">↗</i>
            </a>
            <a href={site.contact.linkedin} target="_blank" rel="noopener noreferrer">
              <span class="coh-contact-link-mark" aria-hidden="true">in</span>
              <span><small>Social</small>LinkedIn</span>
              <i aria-hidden="true">↗</i>
            </a>
            <a href={site.contact.github} target="_blank" rel="noopener noreferrer">
              <span class="coh-contact-link-mark" aria-hidden="true">GH</span>
              <span><small>Code</small>GitHub</span>
              <i aria-hidden="true">↗</i>
            </a>
            <a href="/Neelesh_Jaiswal_Resume_Master.pdf" download="Neelesh_Jaiswal_Resume.pdf" type="application/pdf">
              <span class="coh-contact-link-mark" aria-hidden="true">PDF</span>
              <span><small>Background</small>Download résumé</span>
              <i aria-hidden="true">↓</i>
            </a>
          </nav>
        </div>

        <form
          class="coh-contact-form"
          action={contactFormEndpoint}
          method="POST"
          accept-charset="UTF-8"
          data-coh-contact-form
          data-coh-contact-endpoint={contactFormEndpoint}
          data-coh-reveal
        >
          <div class="coh-contact-form-heading">
            <p>Start a conversation</p>
            <h3>Tell me what you’re building.</h3>
          </div>

          <div class="coh-contact-fields">
            <label>
              <span>Name</span>
              <input type="text" name="name" autocomplete="name" placeholder="Your name" minlength="2" maxlength="120" required />
            </label>
            <label>
              <span>Email</span>
              <input type="email" name="email" autocomplete="email" inputmode="email" placeholder="you@company.com" maxlength="254" required />
            </label>
            <label class="is-wide">
              <span>Company <small>Optional</small></span>
              <input type="text" name="company" autocomplete="organization" placeholder="Where you’re building" maxlength="160" />
            </label>
            <label class="is-wide">
              <span>What can I help with?</span>
              <textarea name="message" rows="5" minlength="20" maxlength="5000" placeholder="Share the product challenge, opportunity, or role you have in mind." required></textarea>
            </label>
          </div>

          <label class="coh-form-trap" aria-hidden="true">
            Leave this field empty
            <input type="text" name="_honey" tabindex="-1" autocomplete="off" />
          </label>
          <div class="coh-contact-submit">
            <button type="submit">
              <span data-coh-contact-submit-label>Send message</span>
              <i aria-hidden="true">↗</i>
            </button>
            <p id="coh-contact-status" role="status" aria-live="polite" data-coh-contact-status>
              Your message will go directly to my inbox.
            </p>
          </div>
        </form>
      </div>
      <footer>
        <span>Neel Jaiswal · Senior Product Manager, Mint Mobile</span>
        <a href="#home">Back to top</a>
        <span>© {new Date().getFullYear()}</span>
      </footer>
    </section>
  </main>
</CohesionLayout>
