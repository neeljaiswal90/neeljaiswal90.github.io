---
import { canonicalUrl } from '../data/site';

const destination = '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Neel Jaiswal — Portfolio</title>
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={canonicalUrl(destination)} />
    <meta http-equiv="refresh" content={`0;url=${destination}`} />
    <script is:inline>
      window.location.replace(`/${window.location.hash}`);
    </script>
  </head>
  <body>
    <p>This portfolio has moved to <a href={destination}>the main site</a>.</p>
  </body>
</html>
