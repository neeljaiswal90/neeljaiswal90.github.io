---
import '../styles/index.css';
import { canonicalUrl, site } from '../data/site';
import { getPublishableClaim } from '../data/claims';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  structuredData?: Record<string, unknown> | readonly Record<string, unknown>[];
  portfolioPage?: boolean;
}

const experience = getPublishableClaim('profile.experience.years_10_plus');

const {
  title = site.title,
  description =
    `Senior product leader with ${experience.displayValue} across AI, eCommerce, growth, enterprise platforms, retail, and regulated products. Explore Neel Jaiswal's work, systems, and public builds.`,
  canonical = canonicalUrl('/'),
  ogTitle = title,
  ogDescription =
    'I turn complex systems into products people adopt — from production AI and telecom commerce to enterprise integrations and self-service.',
  ogImage = canonicalUrl(site.socialImage.path),
  ogType = 'website',
  structuredData,
  portfolioPage,
} = Astro.props;

const canonicalHref = canonicalUrl(canonical);
const imageHref = canonicalUrl(ogImage);
const profileImageHref = canonicalUrl(site.profileImage.path);
const homeHref = canonicalUrl('/');
const personId = `${homeHref}#person`;
const websiteId = `${homeHref}#website`;
const webPageId = `${canonicalHref}#webpage`;
const supplementalStructuredData = (structuredData
  ? Array.isArray(structuredData) ? structuredData : [structuredData]
  : []).map((record) => Object.fromEntries(
    Object.entries(record).filter(([key]) => key !== '@context'),
  ));
const structuredDataDocument = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': personId,
      name: site.name,
      url: homeHref,
      image: {
        '@type': 'ImageObject',
        url: profileImageHref,
        width: site.profileImage.width,
        height: site.profileImage.height,
      },
      jobTitle: site.jobTitle,
      sameAs: [site.contact.github],
      knowsAbout: site.expertise,
    },
    {
      '@type': 'WebSite',
      '@id': websiteId,
      url: homeHref,
      name: site.name,
      description: site.description,
      inLanguage: site.language,
      publisher: { '@id': personId },
    },
    {
      '@type': canonicalHref === homeHref ? 'ProfilePage' : 'WebPage',
      '@id': webPageId,
      url: canonicalHref,
      name: title,
      description,
      inLanguage: site.language,
      isPartOf: { '@id': websiteId },
      mainEntity: canonicalHref === homeHref ? { '@id': personId } : undefined,
      primaryImageOfPage: {
        '@type': 'ImageObject',
        url: imageHref,
        width: site.socialImage.width,
        height: site.socialImage.height,
      },
    },
    ...supplementalStructuredData,
  ],
};
const structuredDataJson = JSON.stringify(structuredDataDocument).replace(/</g, '\\u003c');
const isPortfolioHome = portfolioPage ?? canonicalHref === homeHref;
---

<!doctype html>
<html lang="en" data-theme="studio">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="author" content={site.name}>
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  <meta name="theme-color" content="#f6f7fb">
  <link rel="canonical" href={canonicalHref}>
  <link rel="sitemap" type="application/xml" href={canonicalUrl(site.sitemapPath)}>
  <meta property="og:site_name" content={site.name}>
  <meta property="og:locale" content={site.openGraphLocale}>
  <meta property="og:title" content={ogTitle}>
  <meta property="og:description" content={ogDescription}>
  <meta property="og:image" content={imageHref}>
  <meta property="og:image:secure_url" content={imageHref}>
  <meta property="og:image:type" content={site.socialImage.type}>
  <meta property="og:image:width" content={String(site.socialImage.width)}>
  <meta property="og:image:height" content={String(site.socialImage.height)}>
  <meta property="og:image:alt" content={site.socialImage.alt}>
  <meta property="og:url" content={canonicalHref}>
  <meta property="og:type" content={ogType}>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={ogTitle}>
  <meta name="twitter:description" content={ogDescription}>
  <meta name="twitter:image" content={imageHref}>
  <meta name="twitter:image:alt" content={site.socialImage.alt}>
  <script id="structured-data" is:inline type="application/ld+json" set:html={structuredDataJson}></script>
  <script is:inline define:vars={{ themeStorageKey: site.themeStorageKey }}>
    document.documentElement.classList.add('js');
    try {
      const theme = localStorage.getItem(themeStorageKey);
      const colors = { studio: '#f6f7fb', cinema: '#1a1715', navy: '#0b1220' };
      if (theme && Object.prototype.hasOwnProperty.call(colors, theme)) {
        document.documentElement.dataset.theme = theme;
        document.querySelector('meta[name="theme-color"]')?.setAttribute('content', colors[theme]);
      }
    } catch { /* Storage is optional; Studio remains the default. */ }
  </script>
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%230b1220'/%3E%3Ctext x='32' y='44' font-family='Arial,sans-serif' font-size='32' font-weight='800' text-anchor='middle' fill='%23d6aa52'%3ENJ%3C/text%3E%3C/svg%3E">
</head>
<body class:list={{ 'portfolio-page': isPortfolioHome }}>
  <a class="skip-link" href="#main-content">Skip to portfolio</a>
  <div class="page-progress" aria-hidden="true"><span id="page-progress-bar"></span></div>

  <slot />

  <script>
    import '../scripts/main';
  </script>
</body>
</html>
