---
import BaseLayout from './BaseLayout.astro';
import CasePager from '../components/case-study/CasePager.astro';
import type { WorkCase } from '../data/work';
import { canonicalUrl, site } from '../data/site';
import '../styles/case-study.css';

interface Props {
  caseStudy: WorkCase;
  previous: WorkCase | null;
  next: WorkCase | null;
}

const { caseStudy, previous, next } = Astro.props;
const canonical = canonicalUrl(`/work/${caseStudy.slug}/`);
const home = canonicalUrl('/');
const cohesionHome = canonicalUrl('/');
const personId = `${home}#person`;
const websiteId = `${home}#website`;
const pageTitle = `${caseStudy.title} — ${caseStudy.company} Case Study | Neel Jaiswal`;
const description = caseStudy.summary.length <= 158
  ? caseStudy.summary
  : `${caseStudy.summary.slice(0, 157).replace(/\s+\S*$/, '')}…`;
const structuredData = [
  {
    '@type': 'Article',
    '@id': `${canonical}#case-study`,
    headline: caseStudy.title,
    description,
    abstract: caseStudy.problem,
    articleSection: caseStudy.systemLabel,
    genre: 'Product case study',
    inLanguage: site.language,
    keywords: [caseStudy.company, caseStudy.systemLabel, 'Product leadership'],
    author: { '@id': personId },
    publisher: { '@id': personId },
    isPartOf: { '@id': websiteId },
    mainEntityOfPage: { '@id': `${canonical}#webpage` },
    url: canonical,
    about: {
      '@type': 'Thing',
      name: `${caseStudy.company} · ${caseStudy.systemLabel}`,
    },
  },
  {
    '@type': 'BreadcrumbList',
    '@id': `${canonical}#breadcrumb`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Portfolio', item: home },
      { '@type': 'ListItem', position: 2, name: 'Selected work', item: `${cohesionHome}#work` },
      { '@type': 'ListItem', position: 3, name: caseStudy.title, item: canonical },
    ],
  },
];
---

<BaseLayout
  title={pageTitle}
  description={description}
  canonical={canonical}
  ogTitle={pageTitle}
  ogDescription={description}
  ogType="article"
  structuredData={structuredData}
>
  <div class="case-page" data-controller="case-study-scene">
    <header class="case-topbar">
      <a class="case-brand" href="/#home" aria-label="Neel Jaiswal portfolio home">
        <b>NJ</b>
        <span>Neel Jaiswal<small>Senior Product Manager · Mint Mobile</small></span>
      </a>
      <nav class="case-breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Portfolio</a></li>
          <li><a href="/#work">Selected work</a></li>
          <li aria-current="page">{caseStudy.sequence}</li>
        </ol>
      </nav>
      <a class="case-topbar-back" href="/#work">All work <span aria-hidden="true">↙</span></a>
    </header>

    <main class="case-main" id="main-content">
      <slot />
      <CasePager current={caseStudy} previous={previous} next={next} />
    </main>
  </div>
</BaseLayout>
