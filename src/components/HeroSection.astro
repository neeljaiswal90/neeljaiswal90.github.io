---
import StudyEvidence from './StudyEvidence.astro';
import ResponsiveMedia from './ResponsiveMedia.astro';
import { getPublishableClaim } from '../data/claims';
import { getPublishableMedia } from '../data/media';
import { getProductionSection } from '../data/site';
import '../styles/scenes/hero.css';

const introSection = getProductionSection('intro');
const experience = getPublishableClaim('profile.experience.years_10_plus');
const location = getPublishableClaim('profile.location.greater_san_diego');
const headshot = getPublishableMedia('media.profile.headshot');
---

<section class="chapter hero" id="intro" data-section="intro" data-controller="hero">
  <div class="hero-orbit orbit-one" data-hero-orbit="primary" aria-hidden="true"></div>
  <div class="hero-orbit orbit-two" data-hero-orbit="secondary" aria-hidden="true"></div>

  <div class="hero-grid">
    <div class="hero-copy-block">
      <div class="hero-kicker-row">
        <p class="eyebrow" data-hero-kicker>{introSection.eyebrow}</p>
        <span aria-hidden="true">01 / 08</span>
      </div>

      <h1 class="hero-title" aria-label="I turn complexity into adoption.">
        <span class="hero-line" data-hero-line aria-hidden="true">
          <span class="hero-line__inner" data-hero-line-inner>
            <span class="hero-word" data-hero-word>I</span>{' '}<span class="hero-word" data-hero-word>turn</span>
          </span>
        </span>
        <span class="hero-line" data-hero-line aria-hidden="true">
          <span class="hero-line__inner" data-hero-line-inner>
            <span class="hero-word" data-hero-word>complexity</span>
          </span>
        </span>
        <span class="hero-line hero-line-offset" data-hero-line aria-hidden="true">
          <span class="hero-line__inner" data-hero-line-inner>
            <span class="hero-word" data-hero-word>into</span>{' '}<span class="hero-word gold" data-hero-word>adoption.</span>
          </span>
        </span>
      </h1>

      <div class="hero-lower" data-hero-lower>
        <p class="hero-lead">From a production agentic platform and conversational AI to purchase funnels, enterprise integrations, and regulated products — I connect the customer outcome to the system that has to deliver it.</p>
        <div class="hero-actions">
          <a class="hero-primary" href="#selected-work">Explore selected work <span aria-hidden="true">↗</span></a>
          <a class="text-link" href="#experience">See the full arc <span aria-hidden="true">↓</span></a>
        </div>
      </div>
    </div>

    <aside class="hero-profile-card" aria-label="Neel Jaiswal profile">
      <div class="hero-portrait">
        <ResponsiveMedia media={headshot} width={870} height={827} loading="eager" fetchpriority="high" />
      </div>
      <div class="hero-profile-caption">
        <div><span>Neelesh (Neel) Jaiswal</span><strong>Senior product leader</strong></div>
        <span class="hero-profile-mark" aria-hidden="true">NJ</span>
      </div>
      <dl class="hero-profile-facts">
        <div><dt>{location.displayLabel}</dt><dd>{location.displayValue}</dd></div>
        <div><dt>Experience</dt><dd>{experience.displayValue}</dd></div>
      </dl>
    </aside>
  </div>

  <div class="hero-marquee" aria-hidden="true">
    <div>
      <span>GROWTH</span><i>×</i><span>COMMERCE</span><i>×</i><span>AI</span><i>×</i><span>PLATFORMS</span><i>×</i>
      <span>GROWTH</span><i>×</i><span>COMMERCE</span><i>×</i><span>AI</span><i>×</i><span>PLATFORMS</span><i>×</i>
    </div>
  </div>

  <div class="signal-grid" aria-label="Product leadership focus areas">
    <article class="signal-card spotlight-card" data-hero-signal>
      <div class="signal-card__content" data-hero-signal-content>
        <small>01 / Diagnose</small>
        <strong>Growth</strong>
        <span>Experiments and funnel systems that compound adoption</span>
      </div>
    </article>
    <article class="signal-card spotlight-card" data-hero-signal>
      <div class="signal-card__content" data-hero-signal-content>
        <small>02 / Orchestrate</small>
        <strong>Commerce</strong>
        <span>Purchase, activation, fulfillment, and lifecycle</span>
      </div>
    </article>
    <article class="signal-card spotlight-card" data-hero-signal>
      <div class="signal-card__content" data-hero-signal-content>
        <small>03 / Ground</small>
        <strong>AI</strong>
        <span>Systems measured on resolution and customer value</span>
      </div>
    </article>
    <article class="signal-card spotlight-card" data-hero-signal>
      <div class="signal-card__content" data-hero-signal-content>
        <small>04 / Scale</small>
        <strong>Platforms</strong>
        <span>Integrations and operating models built for adoption</span>
      </div>
    </article>
  </div>

  <StudyEvidence />
</section>
