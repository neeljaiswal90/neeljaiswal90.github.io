---
import { getPublishableClaim } from '../data/claims';
import { projects } from '../data/projects';
import { getProductionSection } from '../data/site';

const section = getProductionSection('builds');
const publicRepositoryCount = getPublishableClaim('github.public_repository_count_5');
const education = getPublishableClaim('education.computer_science_degree');
---

<section class="chapter builds-section" id="builds" data-section="builds">
  <header class="section-header inverse reveal">
    <div>
      <p class="section-number">{section.sequence} / {section.eyebrow}</p>
      <h2>I build what<br />I manage.</h2>
    </div>
    <p>{education.statement} The public work below shows implementation fluency: enough depth to reason with engineering from system boundary to release.</p>
  </header>

  <div class="github-banner reveal">
    <div>
      <span class="github-mark" aria-hidden="true">⌘</span>
      <p><b>@neeljaiswal90</b><br /><span>{publicRepositoryCount.displayValue} · three featured below</span></p>
    </div>
    <a href="https://github.com/neeljaiswal90" target="_blank" rel="noopener">View GitHub profile <span aria-hidden="true">↗</span></a>
  </div>

  <div class="build-grid">
    {projects.map((project, index) => {
      const evidence = getPublishableClaim(project.claimId);
      return (
        <a class:list={['build-card', 'reveal', { featured: index === 0 }]} href={project.url} target="_blank" rel="noopener" aria-label={`${project.title} on GitHub (opens in a new tab)`}>
          <div class="build-top">
            <span class:list={['status-dot', index === 0 ? 'live' : 'public']}></span>
            <span>{evidence.displayLabel} · {project.defaultBranch}</span>
            <i aria-hidden="true">↗</i>
          </div>
          <h3>{project.title}</h3>
          <p>{project.summary}</p>
          <ul>{project.highlights.map((highlight) => <li>{highlight}</li>)}</ul>
          <div class="build-meta" aria-label="Technology stack">
            {project.technologies.map((technology) => <span>{technology}</span>)}
          </div>
          {project.boundary && <small class="build-note">{project.boundary}</small>}
        </a>
      );
    })}
  </div>
</section>
