---
import { site } from '../data/site';
---

<header class="profile-rail" aria-label="Portfolio header" data-controller="theme">
  <div class="profile-rail-inner">
    <div class="profile-topline">
      <a class="monogram" href="#intro" aria-label="NJ — Neel Jaiswal home">NJ</a>
      <div class="profile-copy">
        <strong class="profile-name">Neel Jaiswal</strong>
        <span class="profile-role">Product leader · builder</span>
      </div>
    </div>

    <span class="availability"><i aria-hidden="true"></i> Open to the right role</span>

    <div class="theme-lab" aria-label="Color theme explorer">
      <span class="theme-label">Mood</span>
      <div class="theme-options" role="group" aria-label="Choose a color mood">
        <button type="button" data-theme-option="studio" aria-pressed="true" style="--swatch-a:#f7f9fc;--swatch-b:#4059c7;--swatch-c:#0f7c83">
          <i aria-hidden="true"></i><span>Light studio</span>
        </button>
        <button type="button" data-theme-option="cinema" aria-pressed="false" style="--swatch-a:#171a24;--swatch-b:#6f83d9;--swatch-c:#3f8f92">
          <i aria-hidden="true"></i><span>Cinema</span>
        </button>
        <button type="button" data-theme-option="navy" aria-pressed="false" style="--swatch-a:#0b1220;--swatch-b:#d6aa52;--swatch-c:#f3eee4">
          <i aria-hidden="true"></i><span>Executive</span>
        </button>
      </div>
    </div>

    <nav class="social-links" aria-label="Contact and social links">
      <a href="https://linkedin.com/in/neelesh-jaiswal" target="_blank" rel="noopener">LinkedIn</a>
      <a href={site.contact.github} target="_blank" rel="noopener">GitHub</a>
      <a href="/Neelesh_Jaiswal_Resume_Master.pdf" download>Résumé</a>
    </nav>

    <a class="rail-cta" href={`mailto:${site.contact.email}`}>Start a conversation <span aria-hidden="true">↗</span></a>
  </div>
</header>
