---
import type { AssertionKind, ClaimRecord } from '../../data/claims';
import { sourceById } from '../../data/sources';

interface Props {
  claims: readonly ClaimRecord[];
  boundary: string;
  measurementNote?: string | undefined;
}

const { claims, boundary, measurementNote } = Astro.props;
const assertionLabels: Record<AssertionKind, string> = {
  documented: 'Documented experience',
  'owner-asserted': 'Owner-reported outcome',
  derived: 'Derived measure',
  external: 'External evidence',
};
---

<section class="case-section case-evidence" id="evidence" data-case-scene data-case-section="evidence">
  <header class="case-section-heading">
    <p>09 / Evidence</p>
    <h2>What the evidence can—and cannot—support.</h2>
  </header>

  <div class="case-evidence-boundary">
    <span>Support boundary</span>
    <p>{boundary}</p>
  </div>

  {measurementNote && (
    <div class="case-measurement-note">
      <span>Measurement context</span>
      <p>{measurementNote}</p>
    </div>
  )}

  {claims.length > 0 && (
    <ul class="case-evidence-list" aria-label="Published case evidence">
      {claims.map((claim) => {
        const claimSources = claim.sourceIds
          .map((sourceId) => sourceById.get(sourceId))
          .filter((source) => source !== undefined);
        return (
          <li>
            <div>
              <span>{assertionLabels[claim.assertionKind]}</span>
              <strong>{claim.displayLabel ?? claim.displayValue ?? 'Published evidence'}</strong>
            </div>
            <p>{claim.statement}</p>
            <ul class="case-source-list" aria-label="Sources">
              {claimSources.map((source) => {
                const href = source.publicCitationAllowed ? source.url ?? source.localPath : undefined;
                return <li>{href ? <a href={href}>{source.publisher} <span aria-hidden="true">↗</span></a> : source.publisher}</li>;
              })}
            </ul>
          </li>
        );
      })}
    </ul>
  )}
</section>
