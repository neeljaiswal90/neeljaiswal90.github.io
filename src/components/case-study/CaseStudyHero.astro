---
import type { ClaimRecord } from '../../data/claims';
import type { WorkCase, WorkContextCue } from '../../data/work';
import CompanyLogo from '../CompanyLogo.astro';
import CaseMetricStrip from './CaseMetricStrip.astro';

interface Props {
  caseStudy: WorkCase;
  metrics: readonly ClaimRecord[];
  contextCues: readonly WorkContextCue[];
}

const { caseStudy, metrics, contextCues } = Astro.props;
---

<header class="case-hero" id="overview" data-case-scene data-case-section="overview">
  <div class="case-hero-grid" aria-hidden="true"></div>
  <div class="case-hero-meta">
    <span>{caseStudy.sequence} / {caseStudy.systemLabel}</span>
    <span class="case-company-lockup">
      <CompanyLogo company={caseStudy.company} class="case-company-logo" />
      <b>{caseStudy.company}</b>
    </span>
  </div>
  <h1 data-case-title>{caseStudy.title}</h1>
  <p class="case-hero-summary">{caseStudy.summary}</p>
  <div class="case-at-glance" aria-label="Case study at a glance">
    <span>At a glance</span>
    <dl>
      <div><dt>Role</dt><dd>{caseStudy.role}</dd></div>
      <div><dt>Period</dt><dd>{caseStudy.period}</dd></div>
      <div><dt>Team</dt><dd>{caseStudy.team}</dd></div>
      <div><dt>Customer</dt><dd>{caseStudy.customer}</dd></div>
      <div><dt>Surface</dt><dd>{caseStudy.surface}</dd></div>
    </dl>
  </div>
  <CaseMetricStrip metrics={metrics} />
  {contextCues.length > 0 && (
    <div class="case-scope" aria-label="Case scope cues">
      <span>Scope cues</span>
      <ul>
        {contextCues.map((signal) => (
          <li><strong>{signal.value}</strong><small>{signal.label}</small></li>
        ))}
      </ul>
    </div>
  )}
</header>
